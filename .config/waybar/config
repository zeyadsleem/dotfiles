{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    // "height": 30, // Auto-height is used when commented
    // "width": 1280, // Full screen width when commented
    "spacing": 4, // Gaps between modules (in px)
    // See `man waybar` for more configuration options

// Configuration - modules-left

    "modules-left": [
        "custom/launcher",
        "sway/workspaces",
        "sway/mode",
        "sway/window"
    ],

    "custom/launcher": {
        "format":"<span size='x-large'>’īó</span>",
        "on-click": "exec nwg-drawer",
        "tooltip": false
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "3": "3",
            "4": "4",
            "5": "5",
            "6": "6",
            "7": "7",
            "8": "8",
            "9": "9",
            "10": "10"
        }
    },

    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>",
        "tooltip": false
    },

    "sway/window": {
        "format": "{}",
        //"all-outputs": true, // Active window shows only on active display when commented
        "max-length": 120
    },

    "network": {
        "format-wifi": "’ć½  {bandwidthDownBits:>} ¾░ČĪ {bandwidthUpBits:>} ¾░ČŻ",
        "format-ethernet": "¾░łĆ  {bandwidthDownBits:>} ¾░ČĪ {bandwidthUpBits:>} ¾░ČŻ",
        "tooltip-format": "{essid} - {ipaddr}",
        "format-linked": "{ifname}",
        "format-disconnected": "’ü▒  Disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "interval": 1,
        // "on-click": "wezterm start --class waybar_nmtui -- nmtui"
    },

// Configuration - modules-center

    "modules-center": [
        "network"
    ],


// Configuration - modules-right

    "modules-right": [
        "sway/language",
        "clock",
        "custom/notification",
        "group/hardware",
        "idle_inhibitor",
        "backlight",
        "pulseaudio",
        "battery",
        "tray",
        "custom/power"
    ],

    "group/hardware": {
        "orientation": "horizontal",
        "modules": [
            "cpu",
            "memory"
        ]
    },

    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
            "none": "’éó",
            "dnd-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
            "dnd-none": "’ćĘ",
            "inhibited-notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
            "inhibited-none": "’éó",
            "dnd-inhibited-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
            "dnd-inhibited-none": "’ćĘ"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    "sway/language": {
        "format": "{}",
        "format-en": "­¤ć║­¤ćĖ",
        "format-ar": "­¤ć¬­¤ć¼",
        "on-click": "~/.local/bin/switch-layout.sh"
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "’ü«",
            "deactivated": "’ü░"
        },
        "tooltip-format-activated": "Idle Inhibitor Activated",
        "tooltip-format-deactivated": "Idle Inhibitor Deactivated"
    },

    "cpu": {
        "interval": 5,
        "format": "’Æ╝{usage:>3}%",
        "states": {
            "warning": 70,
            "critical": 90,
        },
        "on-click": "wezterm start --class waybar_btop -- btop"
    },

    "memory": {
        "interval": 5,
        "format": "Ņ┐ģ{:>3}%",
        "on-click": "wezterm start --class waybar_btop -- btop",
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["¾░ä░", "¾░¬×", "¾░¬¤", "¾░¬Ā", "¾░¬Ī", "¾░¬ó", "¾░¬Ż", "¾░¬ż", "¾░¬ź"],
        "tooltip-format": "Backlight (Scroll): {percent:}%",
        "on-scroll-down": "brightnessctl -c backlight set 5%-",
        "on-scroll-up": "brightnessctl -c backlight set +5%"
    },

    "pulseaudio": {
        "scroll-step": 2,
        "format": "{icon} {volume}%",
        "format-muted":"¾░Ø¤ muted",
        "format-icons": {
            "headphones": "’Ćź",
            "handsfree": "’Ćź",
            "headset": "’Ćź",
            "phone": "’éĢ",
            "portable": "’éĢ",
            "car": "’å╣",
            "default": ["¾░Ģ┐", "¾░¢Ć", "¾░ĢŠ"]
        },
        "on-click": "pavucontrol"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"]
    },

    "clock": {
        "format": "’ĆŚ {:%I:%M %p}",
        "format-alt": "’ĆŚ {:%H:%M}",
        "tooltip-format": "<span>{:%A, %d %B %Y}</span>",
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "tray": {
        "icon-size": 16,
        "spacing":10
     },

    "custom/power": {
        "format":"ŌÅ╗",
        "on-click": "exec ~/.config/sway/scripts/power_menu.sh",
        "tooltip": false
    },
}
